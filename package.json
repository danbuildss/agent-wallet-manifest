{
  "name": "agent-wallet-manifest",
  "version": "1.0.0",
  "description": "Open standard schema and validator for publishing verified wallet addresses used by autonomous agents.",
  "keywords": ["agent", "wallet", "manifest", "standard", "ai-agent", "onchain", "financial-identity"],
  "homepage": "https://github.com/danbuildss/agent-wallet-manifest",
  "repository": {
    "type": "git",
    "url": "https://github.com/danbuildss/agent-wallet-manifest.git"
  },
  "license": "MIT",
  "bin": {
    "agent-wallet-manifest": "./dist/validate.js"
  },
  "scripts": {
    "validate": "ts-node validator/validate.ts",
